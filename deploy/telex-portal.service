[Unit]
Description=Telex Configuration Portal (always-on)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/telex/client/portal
ExecStart=/opt/telex/venv/bin/python portal.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target

# ── Obligatoire ───────────────────────────────────────────────────────────────
ADMIN_API_KEY=changez-moi-avec-une-longue-chaine-aleatoire

# ── Alertes email (optionnel mais fortement recommandé) ───────────────────────
# Adresse qui reçoit les alertes de sécurité
ADMIN_EMAIL=votre@email.com

# Serveur SMTP (exemple Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre@gmail.com
SMTP_PASSWORD=mot-de-passe-application-gmail
SMTP_FROM=telex@votre-domaine.com

# Exemple avec un serveur SMTP propre (Mailgun, Brevo, etc.)
# SMTP_HOST=smtp.eu.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@mg.votre-domaine.com
# SMTP_PASSWORD=votre-cle-api-mailgun
